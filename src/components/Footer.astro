---
import { site } from "../data/site";
import Phone from "./icons/Phone.astro";
import WhatsApp from "./icons/WhatsApp.astro";

const year = new Date().getFullYear();
const itineraire =
  "https://www.google.com/maps/dir/?api=1&destination=48.8001684,1.9510758";
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <span class="site-footer__name">{site.name}</span>
      <p class="site-footer__pitch">
        Dératisation et désinsectisation en Île-de-France. Intervention rapide,
        techniciens certifiés.
      </p>
    </div>

    <div class="site-footer__contact">
      <h2 class="site-footer__title">Coordonnées</h2>
      <address class="site-footer__address">
        {site.address.street}<br />
        {site.address.postalCode} {site.address.city}
      </address>

      <ul class="site-footer__contacts" role="list">
        <li>
          <a href={site.phoneHref}>
            <Phone size={16} />
            <span>{site.phone}</span>
          </a>
        </li>
        <li>
          <a
            class="site-footer__wa"
            href="https://wa.me/33661295767"
            target="_blank"
            rel="noopener"
          >
            <WhatsApp size={16} />
            <span>WhatsApp</span>
          </a>
        </li>
        <li>
          <a href={`mailto:${site.email}`}>
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2"></rect>
              <path d="m3.5 7 8.5 6 8.5-6"></path>
            </svg>
            <span>{site.email}</span>
          </a>
        </li>
      </ul>

      <div class="site-footer__map">
        <iframe src="https://maps.google.com/maps?q=48.8001684,1.9510758&t=h&z=16&hl=fr&output=embed" width="100%" height="240" style="border:0" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Localisation Garbi-Protect"></iframe>
      </div>

      <a
        class="btn btn--on-dark site-footer__route"
        href={itineraire}
        target="_blank"
        rel="noopener"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polygon points="3 11 22 2 13 21 11 13 3 11"></polygon>
        </svg>
        <span>Itinéraire</span>
      </a>
    </div>

    <nav class="site-footer__nav" aria-label="Plan du site">
      <h2 class="site-footer__title">Plan du site</h2>
      <ul role="list">
        <li><a href="/#nuisibles">Nuisibles</a></li>
        <li><a href="/#secteurs">Secteurs d'intervention</a></li>
        <li><a href="/#tarifs">Tarifs</a></li>
        <li><a href="/devis">Demander un devis</a></li>
        <li><a href="/devis">Contact</a></li>
      </ul>
    </nav>
  </div>

  <div class="site-footer__bar">
    <div class="container site-footer__bar-inner">
      <p>© {year} {site.name}. Tous droits réservés.</p>
      <ul role="list" class="site-footer__legal">
        <li><a href="/mentions-legales">Mentions légales</a></li>
        <li><a href="/cgv">CGV</a></li>
      </ul>
    </div>
  </div>
</footer>

<style lang="scss">
  @use "../styles/mixins" as *;

  .site-footer {
    background-color: var(--color-footer-bg);
    color: var(--color-ink-200);
  }

  .site-footer__grid {
    display: grid;
    gap: var(--space-8);
    padding-block: var(--space-9);

    @include bp("md") {
      grid-template-columns: 1.3fr 1.1fr 1fr;
      gap: var(--space-7);
      align-items: start;
    }
  }

  .site-footer__name {
    display: block;
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    color: var(--color-on-brand);
    margin-bottom: var(--space-4);
  }

  .site-footer__pitch {
    max-width: 34ch;
    color: var(--color-ink-300);
  }

  .site-footer__title {
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brand-200);
    margin-bottom: var(--space-5);
  }

  .site-footer__address {
    font-style: normal;
    line-height: 1.8;
    margin-bottom: var(--space-5);
  }

  .site-footer__contacts {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .site-footer__contacts a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .site-footer__contacts :global(svg) {
    flex-shrink: 0;
  }

  // Icone WhatsApp dans son vert officiel ; le texte reste en couleur de footer.
  .site-footer__wa :global(svg) {
    color: #25d366;
  }

  // Carte satellite : coins arrondis, ombre douce du site, jamais plus large que
  // sa colonne. L'iframe garde sa hauteur native (~240px).
  .site-footer__map {
    margin-bottom: var(--space-4);
    overflow: hidden;
    line-height: 0;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .site-footer__map iframe {
    display: block;
    width: 100%;
  }

  // Bouton blanc sur fond bleu : on garde ses couleurs btn--on-dark malgre la
  // regle generale des liens du footer (plus specifique ici).
  .site-footer .site-footer__route {
    width: fit-content;
    color: var(--color-brand-700);
  }

  .site-footer__nav ul {
    display: grid;
    gap: var(--space-3);
  }

  .site-footer a {
    color: var(--color-ink-200);
  }

  .site-footer a:hover {
    color: var(--color-brand-200);
  }

  .site-footer .site-footer__route:hover {
    color: var(--color-brand-800);
  }

  .site-footer__bar {
    background-color: var(--color-footer-bar);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .site-footer__bar-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-block: var(--space-6);
    font-size: var(--fs-sm);
    color: var(--color-ink-300);

    @include bp("sm") {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .site-footer__legal {
    display: flex;
    gap: var(--space-5);
  }
</style>
