---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Conditions générales de vente, Garbi-Protect"
  description="Conditions générales de vente de Garbi-Protect."
  noindex={true}
>
  <section class="section">
    <div class="container legal">
      <h1>Conditions générales de vente</h1>
      <p>
        Cette page sera complétée avec les conditions générales de vente
        définitives de Garbi-Protect.
      </p>
      <p><a href="/">Retour à l'accueil</a></p>
    </div>
  </section>
</Layout>

<style>
  .legal {
    max-width: var(--container-narrow);
  }

  .legal p {
    margin-top: var(--space-5);
    color: var(--color-text-muted);
  }
</style>
