---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Phone from "../components/icons/Phone.astro";
import WhatsApp from "../components/icons/WhatsApp.astro";
import PestIcon from "../components/icons/PestIcon.astro";
import { site } from "../data/site";
import { nuisibles } from "../data/nuisibles";

import type { ImageMetadata } from "astro";

// Photo du hero. Pour changer l'image, remplace ce seul import (ou remplace le
// fichier src/assets/hero-intervention.png en gardant le meme nom).
import heroPhoto from "../assets/hero-intervention.png";

// Photos des nuisibles. Chaque carte pointe vers un fichier de ce dossier via
// son champ `image` (voir src/data/nuisibles.ts) : pour remplacer une photo,
// on garde le meme nom de fichier, ou on change le champ `image`. Un seul endroit.
const nuisibleImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/nuisibles/*.{png,jpg,jpeg,webp}",
  { eager: true },
);
const nuisibleImage = (file: string): ImageMetadata =>
  nuisibleImages[`../assets/nuisibles/${file}`].default;

const heroPoints = [
  "Intervention sous 2h en urgence",
  "Techniciens Certibiocide",
  "Devis clair",
];

const etapes = [
  {
    titre: "On diagnostique",
    texte:
      "On cerne le problème au téléphone puis sur place, et on établit un plan d'action. Devis rapide.",
    icon: `<circle cx="11" cy="11" r="6.5"/><line x1="15.8" y1="15.8" x2="20.5" y2="20.5"/>`,
  },
  {
    titre: "On traite",
    texte:
      "Un technicien certifié applique la bonne méthode selon le nuisible (détection thermique, vapeur sèche, traitements ciblés). Un technicien peut intervenir dans la journée.",
    icon: `<circle cx="12" cy="12" r="7.5"/><circle cx="12" cy="12" r="2.4"/><line x1="12" y1="1.6" x2="12" y2="4.4"/><line x1="12" y1="19.6" x2="12" y2="22.4"/><line x1="1.6" y1="12" x2="4.4" y2="12"/><line x1="19.6" y1="12" x2="22.4" y2="12"/>`,
  },
  {
    titre: "On suit",
    texte:
      "Passage de contrôle et conseils de prévention pour éviter la récidive. Suivi et garantie.",
    icon: `<rect x="4" y="5" width="16" height="16" rx="2"/><line x1="4" y1="9.5" x2="20" y2="9.5"/><line x1="8.5" y1="3" x2="8.5" y2="6.5"/><line x1="15.5" y1="3" x2="15.5" y2="6.5"/><path d="m9 14.5 2 2 4-4"/>`,
  },
];

const engagements = [
  {
    titre: "Techniciens Certibiocide",
    texte: "Produits homologués, appliqués dans les règles.",
    icon: `<path d="M12 3 5 6v5c0 4 3 7 7 9 4-2 7-5 7-9V6l-7-3Z"/><path d="m9 11.5 2 2 4-4"/>`,
  },
  {
    titre: "Intervention sous 2h",
    texte: "En urgence, partout en Île-de-France.",
    icon: `<path d="m13 3-7 9h5l-1 7 7-9h-5l1-7Z"/>`,
  },
  {
    titre: "Devis clair",
    texte: "Un prix annoncé avant, sans surprise après.",
    icon: `<rect x="5" y="3" width="14" height="18" rx="2"/><line x1="8.5" y1="8" x2="15.5" y2="8"/><line x1="8.5" y1="12" x2="15.5" y2="12"/><line x1="8.5" y1="16" x2="13" y2="16"/>`,
  },
  {
    titre: "Suivi inclus",
    texte: "On reste joignables après le passage.",
    icon: `<path d="M20 11a8 8 0 1 0-2.3 5.6"/><path d="M20 5v5h-5"/>`,
  },
];

const departements = [
  { code: "75", nom: "Paris" },
  { code: "77", nom: "Seine-et-Marne" },
  { code: "78", nom: "Yvelines" },
  { code: "91", nom: "Essonne" },
  { code: "92", nom: "Hauts-de-Seine" },
  { code: "93", nom: "Seine-Saint-Denis" },
  { code: "94", nom: "Val-de-Marne" },
  { code: "95", nom: "Val-d'Oise" },
];

const tarifs = [
  {
    titre: "Punaises de lit",
    prix: "199",
    soustitre: "Traitement complet avec garantie",
    inclus: [
      "Main d'œuvre",
      "Frais de déplacement",
      "Rapport d'intervention",
      "Garantie 2 mois",
    ],
  },
  {
    titre: "Dératisation",
    prix: "149",
    soustitre: "Traitement complet avec diagnostic",
    inclus: [
      "Diagnostic",
      "Main d'œuvre",
      "Frais de déplacement",
      "Rapport d'intervention",
    ],
  },
  {
    titre: "Désinsectisation",
    prix: "149",
    soustitre: "Traitement complet avec garantie",
    inclus: [
      "Main d'œuvre",
      "Frais de déplacement",
      "Rapport d'intervention",
      "Garantie 2 mois",
    ],
  },
];

// Avis Google reels (texte exact fourni par le client), 5 etoiles chacun. Pour
// ajouter ou retirer un avis, edite ce tableau. Ne jamais inventer d'avis.
const avis = [
  { nom: "Lucille de Rochegonde", texte: "Entreprise fiable et réactive ! Merci pour votre intervention ! Je recommande" },
  { nom: "Basile de Margerie", texte: "Entreprise très réactive et professionnelle, et leur intervention a permis d'éradiquer définitivement les nuisibles. Je recommande !" },
  { nom: "Rogé Cavailles", texte: "Super expérience avec Garbi Protect. Équipe sérieuse, réactive et hyper sympa. Je recommande sans hésiter !" },
  { nom: "Baptiste", texte: "Équipe réactive et fiable, intervention rapide. Nous voilà débarrassés de tous nuisibles dans la copropriété. Je recommande !" },
  { nom: "Eléonore Aubinaud", texte: "Entreprise fiable et d'une réactivité bluffante. Ils sont à l'écoute avec toujours une solution. Je recommande !" },
  { nom: "Claire", texte: "Très bonne expérience avec Garbi-Protect. Ils ont été super efficaces pour intervenir et gérer mon infestation. Merci encore ! Je les recommande sans hésiter !" },
  { nom: "Tanguy de Poncins", texte: "Très réactif !" },
  { nom: "Constance Simon", texte: "Intervention rapide et efficace et à un prix abordable ! Merci l'équipe !" },
  { nom: "Ombline Daubin", texte: "Réactifs, pro, performants. Je recommande" },
  { nom: "Godefroy Daubin", texte: "Très réactifs et efficaces, je recommande ! La copropriété se débarrasse enfin des nuisibles dans la cave" },
  { nom: "Henry Hurlé", texte: "Le technicien est venu le lendemain de mon appel, et m'a débarrassé des souris qui résistaient à mes pièges et mes poisons. Super service" },
  { nom: "Florian C", texte: "Extrêmement satisfait de Garbi Protect. Intervention rapide, efficace, à des prix très raisonnables. Contact humain remarquable. Je recommande." },
  { nom: "Constance Parfait", texte: "Société très réactive et professionnelle, solution très efficace contre les rats. Je recommande !" },
  { nom: "Isaure Savouré", texte: "Très efficace et réactif !" },
  { nom: "Marie Gastines", texte: "Service efficace et professionnel. Mon problème de souris a été rapidement réglé. Très satisfaite, je recommande" },
];

const avisInitiales = (nom: string): string => {
  const mots = nom.split(" ").filter(Boolean);
  if (mots.length === 1) return mots[0].slice(0, 1).toUpperCase();
  return (mots[0][0] + mots[mots.length - 1][0]).toUpperCase();
};

// Note moyenne et nombre d'avis Google. A changer ICI (un seul endroit) quand de
// nouveaux avis arrivent : la note alimente aussi les etoiles de l'entete avis.
const avisNote = "5";
const avisTotal = "46";
const avisUrl =
  "https://www.google.com/maps/place/Garbi-Protect/@48.8001719,1.9485009,804m/data=!3m1!1e3!4m8!3m7!1s0x47e6854e50ba2df7:0xf4b3bad6450987fd!8m2!3d48.8001684!4d1.9510758!9m1!1b1!16s%2Fg%2F11yppptl6n";

// Repartition en 3 colonnes pour le mur d'avis qui defile doucement.
const avisColonnes = [avis.slice(0, 5), avis.slice(5, 10), avis.slice(10, 15)];

const etoiles = [0, 1, 2, 3, 4];
const starPath =
  "M12 3.6l2.5 5.1 5.6.8-4.1 4 1 5.6L12 16.5 7 19.1l1-5.6-4.1-4 5.6-.8z";
---

<Layout
  title="Garbi-Protect, dératisation et désinsectisation en Île-de-France"
  description="Garbi-Protect intervient contre rats, souris, punaises de lit, cafards et guêpes en Île-de-France. Techniciens Certibiocide, intervention en urgence sous 2h."
>
  <section class="hero">
    <Image
      class="hero__bg"
      src={heroPhoto}
      alt="Deux techniciens Garbi-Protect devant leur véhicule d'intervention en Île-de-France."
      widths={[768, 1280, 1600]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero__veil" aria-hidden="true"></div>

    <div class="container hero__inner">
      <p class="eyebrow hero__eyebrow">
        Punaises de lit · Dératisation · Désinsectisation
      </p>
      <h1 class="hero__title">
        Un nuisible chez vous ? On intervient vite et bien.
      </h1>
      <p class="hero__lead">
        Intervention rapide partout en Île-de-France. Devis gratuit, prix annoncé
        avant l'intervention.
      </p>

      <div class="hero__actions">
        <a class="btn btn--on-dark" href="/devis">Demander un devis</a>
        <a class="btn hero__ghost" href={site.phoneHref}>
          <Phone size={18} />
          <span>Appeler le {site.phone}</span>
        </a>
        <a
          class="btn hero__ghost hero__wa"
          href={site.whatsapp}
          target="_blank"
          rel="noopener"
          aria-label="Nous écrire sur WhatsApp"
        >
          <WhatsApp size={18} />
          <span>WhatsApp</span>
        </a>
      </div>

      <ul role="list" class="hero__points">
        {
          heroPoints.map((p) => (
            <li>
              <svg
                class="hero__check"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m5 12.5 4.2 4.2L19 7" />
              </svg>
              <span>{p}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section section--muted" id="nuisibles" aria-labelledby="nuisibles-titre">
    <div class="container">
      <div class="section-head section-head--center reveal">
        <p class="eyebrow">Nos interventions</p>
        <h2 id="nuisibles-titre">Quel nuisible vous gêne ?</h2>
        <p class="section-head__lead">
          On traite les nuisibles les plus courants des logements et des locaux
          en Île-de-France. Choisissez le vôtre.
        </p>
      </div>

      <ul role="list" class="nuisibles">
        {
          nuisibles.map((n, i) => (
            <li class="reveal" style={`--reveal-delay:${i * 60}ms`}>
              <a class="card nuisible" href={`/devis?nuisible=${n.slug}`}>
                <span
                  class:list={[
                    "nuisible__disc",
                    n.image ? "nuisible__disc--photo" : "nuisible__disc--icon",
                  ]}
                  aria-hidden="true"
                >
                  {n.image ? (
                    <Image
                      class="nuisible__photo"
                      src={nuisibleImage(n.image)}
                      alt=""
                      widths={[88, 132, 176]}
                      sizes="5.5rem"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <PestIcon name={n.slug} />
                  )}
                </span>
                <span class="nuisible__name">{n.name}</span>
                <span class="nuisible__tagline">{n.tagline}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section" aria-labelledby="etapes-titre">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">Comment ça se passe</p>
        <h2 id="etapes-titre">Trois étapes, aucune mauvaise surprise</h2>
        <p class="section-head__lead">
          De votre appel au contrôle final, on garde les choses simples et
          lisibles.
        </p>
      </div>

      <ol role="list" class="parcours">
        {
          etapes.map((e, i) => (
            <li class="parcours__etape reveal" style={`--reveal-delay:${i * 120}ms`}>
              <span class="parcours__badge">
                <span class="parcours__num" aria-hidden="true">{i + 1}</span>
              </span>
              <div class="parcours__content">
                <span class="parcours__icon" aria-hidden="true">
                  <svg
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    set:html={e.icon}
                  />
                </span>
                <h3 class="parcours__titre">{e.titre}</h3>
                <p class="parcours__texte">{e.texte}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section section--muted engagements-section" aria-labelledby="engagements-titre">
    <div class="container engagements">
      <div class="engagements__intro reveal">
        <p class="eyebrow">Pourquoi Garbi-Protect</p>
        <h2 id="engagements-titre">Une entreprise locale, des méthodes sérieuses</h2>
        <p class="section-head__lead">
          Basés à Plaisir, dans les Yvelines, on couvre toute l'Île-de-France.
          Le travail est fait dans les règles, et on l'assume après le passage.
        </p>
        <a class="btn btn--primary engagements__cta" href={site.phoneHref}>
          <Phone size={18} />
          <span>{site.phone}</span>
        </a>
      </div>

      <ul role="list" class="engagements__grid">
        {
          engagements.map((eng, i) => (
            <li class="card engagement reveal" style={`--reveal-delay:${i * 70}ms`}>
              <span class="engagement__icon" aria-hidden="true">
                <svg
                  width="22"
                  height="22"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={eng.icon}
                />
              </span>
              <h3 class="engagement__titre">{eng.titre}</h3>
              <p class="engagement__texte">{eng.texte}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section" id="tarifs" aria-labelledby="prix-titre">
    <div class="container">
      <div class="section-head section-head--center reveal">
        <h2 id="prix-titre">Nos tarifs</h2>
        <p class="section-head__lead">
          Un forfait clair selon le type d'intervention.
        </p>
        <p class="tarifs__rappel">
          <svg
            class="tarifs__check"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="m5 12.5 4.2 4.2L19 7"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
          Devis gratuit, prix annoncé avant l'intervention.
        </p>
      </div>

      <ul role="list" class="tarifs">
        {
          tarifs.map((t, i) => (
            <li class="card tarif reveal" style={`--reveal-delay:${i * 80}ms`}>
              <div class="tarif__head">
                <h3 class="tarif__titre">{t.titre}</h3>
                <p class="tarif__prix">
                  <span class="tarif__from">À partir de</span>
                  <span class="tarif__value">{t.prix} €</span>
                </p>
                <p class="tarif__soustitre">{t.soustitre}</p>
              </div>

              <ul role="list" class="tarif__inclus">
                {t.inclus.map((item) => (
                  <li>
                    <svg
                      class="tarif__tick"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        d="m5 12.5 4.2 4.2L19 7"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>

              <a class="btn btn--primary tarif__cta" href="/devis">
                Obtenir un devis
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section section--muted avis" id="avis" aria-labelledby="avis-titre">
    <div class="container">
      <div class="section-head section-head--center reveal">
        <p class="eyebrow">Votre avis compte</p>
        <h2 id="avis-titre">Ils nous font confiance</h2>
        <p class="section-head__lead">
          Les témoignages de nos clients en Île-de-France.
        </p>

        <div
          class="avis-note"
          aria-label={`Note moyenne ${avisNote} sur 5, ${avisTotal} avis sur Google`}
        >
          <span class="avis-note__stars" aria-hidden="true">
            {etoiles.map(() => (
              <svg class="star star--on" width="20" height="20" viewBox="0 0 24 24">
                <path d={starPath} />
              </svg>
            ))}
          </span>
          <span class="avis-note__score">{avisNote} sur 5</span>
          <span class="avis-note__count">{avisTotal} avis sur Google</span>
        </div>

        <a
          class="btn btn--ghost avis__cta"
          href={avisUrl}
          target="_blank"
          rel="noopener"
        >
          Voir tous les avis sur Google
        </a>
      </div>

      <div class="avis-wall" role="region" aria-label="Avis clients publiés sur Google">
        {
          avisColonnes.map((colonne, ci) => (
            <ul
              role="list"
              class={`avis-col avis-col--${ci + 1}`}
              style={`--avis-duration:${30 + ci * 7}s`}
            >
              {[0, 1].map((copie) => (
                <Fragment>
                  {colonne.map((a) => (
                    <li class="card avis-card" aria-hidden={copie === 1 ? "true" : "false"}>
                      <div class="avis-card__stars" aria-label="Noté 5 sur 5">
                        {etoiles.map(() => (
                          <svg class="star star--on" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                            <path d={starPath} />
                          </svg>
                        ))}
                      </div>
                      <p class="avis-card__text">{a.texte}</p>
                      <div class="avis-card__author">
                        <span class="avis-card__avatar" aria-hidden="true">
                          {avisInitiales(a.nom)}
                        </span>
                        <span class="avis-card__meta">
                          <span class="avis-card__name">{a.nom}</span>
                          <span class="avis-card__source">Avis Google</span>
                        </span>
                      </div>
                    </li>
                  ))}
                </Fragment>
              ))}
            </ul>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="secteurs" aria-labelledby="zones-titre">
    <div class="container">
      <div class="section-head section-head--center reveal">
        <p class="eyebrow">Zones d'intervention</p>
        <h2 id="zones-titre">On se déplace dans toute l'Île-de-France</h2>
      </div>

      <ul role="list" class="zones reveal">
        {
          departements.map((d) => (
            <li>
              <a class="zone" href="/devis">
                <span class="zone__code">{d.code}</span>
                <span class="zone__nom">{d.nom}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="devis" id="devis" aria-labelledby="devis-titre">
    <div class="container devis__inner reveal">
      <div class="devis__text">
        <p class="eyebrow devis__eyebrow">Devis gratuit</p>
        <h2 id="devis-titre" class="devis__titre">Demandez votre devis gratuit</h2>
        <p class="devis__lead">
          Décrivez votre problème en deux minutes. On vous répond avec un prix
          clair, annoncé avant l'intervention.
        </p>
        <p class="devis__call">
          Besoin d'une réponse tout de suite ?
          <a href={site.phoneHref}>Appelez le {site.phone}</a>.
        </p>
      </div>

      <form
        class="devis__card card"
        name="devis-rapide"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/merci"
      >
        <input type="hidden" name="form-name" value="devis-rapide" />
        <p class="devis__hp" hidden>
          <label>Ne pas remplir : <input name="bot-field" /></label>
        </p>

        <p class="devis__card-title">Premier aperçu</p>

        <div class="field">
          <label class="field__label" for="rapide-nom">Nom</label>
          <input class="field__input" id="rapide-nom" name="nom" type="text" autocomplete="name" required />
        </div>

        <div class="field">
          <label class="field__label" for="rapide-tel">Téléphone</label>
          <input class="field__input" id="rapide-tel" name="telephone" type="tel" autocomplete="tel" required />
        </div>

        <div class="field">
          <label class="field__label" for="rapide-type">Type de nuisible</label>
          <select class="field__input" id="rapide-type" name="nuisible" required>
            <option value="">Choisir…</option>
            {
              nuisibles.map((n) => (
                <option value={n.slug}>{n.name}</option>
              ))
            }
          </select>
        </div>

        <button class="btn btn--primary devis__submit" type="submit">
          Demander un devis gratuit
        </button>

        <p class="devis__hint">
          Besoin de tout détailler ?{" "}
          <a href="/devis">Le formulaire complet est sur la page devis.</a>
        </p>
      </form>
    </div>
  </section>
</Layout>

<style lang="scss">
  @use "../styles/mixins" as *;

  // ---------------------------------------------------------------------------
  // Hero pleine largeur — photo d'intervention en fond (object-fit: cover) sous
  // un voile degrade bleu de marque (#002A66 -> #003C95) assez opaque : la photo
  // reste mise en valeur sans etre brute, et le texte blanc reste tres lisible.
  // Contenu centre, aere, typo large. Aucun mouvement (rien a desactiver).
  // ---------------------------------------------------------------------------
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 80vh;
    padding-block: var(--space-9);
    overflow: hidden;
    color: var(--color-on-brand);
    background-color: var(--color-brand-800);

    @include bp("lg") {
      padding-block: var(--space-10);
    }
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image: linear-gradient(
      160deg,
      rgba(0, 42, 102, 0.94) 0%,
      rgba(0, 60, 149, 0.85) 100%
    );
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-5);
    color: var(--color-accent);
  }

  .hero__title {
    max-width: 20ch;
    color: var(--color-on-brand);
    font-size: var(--fs-display);
    text-wrap: balance;
  }

  .hero__lead {
    margin-top: var(--space-6);
    max-width: 54ch;
    font-size: var(--fs-md);
    color: rgba(255, 255, 255, 0.92);
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-4);
    width: 100%;
    max-width: 22rem;
    margin-top: var(--space-8);

    @include bp("sm") {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      width: auto;
      max-width: none;
    }
  }

  .hero__ghost {
    color: var(--color-on-brand);
    border-color: rgba(255, 255, 255, 0.55);
  }

  .hero__ghost:hover {
    border-color: var(--color-on-brand);
    background-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  // Icone WhatsApp en vert officiel sur le bouton contour.
  .hero__wa :global(svg) {
    color: #25d366;
  }

  .hero__points {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3) var(--space-5);
    margin-top: var(--space-8);
    font-weight: var(--fw-medium);
    color: rgba(255, 255, 255, 0.9);
  }

  .hero__points li {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .hero__check {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__ghost:hover {
      transform: none;
    }
  }

  // ---------------------------------------------------------------------------
  // Nuisibles en "ronds" — cartes nettes, disque bleu, icone monoline.
  // ---------------------------------------------------------------------------
  .nuisibles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);

    @include bp("sm") {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }

    @include bp("md") {
      grid-template-columns: repeat(4, 1fr);
    }

    @include bp("lg") {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .nuisible {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2);
    height: 100%;
    padding: var(--space-6) var(--space-4);
    color: var(--color-text);
  }

  .nuisible__disc {
    display: grid;
    place-items: center;
    width: 5.5rem;
    height: 5.5rem;
    margin-bottom: var(--space-3);
    overflow: hidden;
    isolation: isolate;
    color: var(--color-brand-600);
    background-color: var(--color-brand-50);
    border-radius: var(--radius-pill);
    transition: background-color var(--transition-base),
      color var(--transition-base), transform var(--transition-base);
  }

  // Photos de nuisibles : fond blanc neutralise par le multiply pour se fondre
  // dans le disque bleu clair commun a toutes les cartes. Cadrage identique
  // (meme disque, meme contain, meme retrait) pour toutes les photos.
  .nuisible__photo {
    width: 100%;
    height: 100%;
    padding: 0.5rem;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .nuisible__name {
    font-size: var(--fs-md);
    font-weight: var(--fw-semibold);
    color: var(--color-ink-900);
  }

  .nuisible__tagline {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    line-height: var(--lh-snug);
    text-wrap: balance;
  }

  .nuisible:hover .nuisible__disc {
    transform: scale(1.06);
  }

  .nuisible:hover .nuisible__disc--icon {
    color: #ffffff;
    background-color: var(--color-brand-500);
  }

  // ---------------------------------------------------------------------------
  // Parcours "Comment ca se passe" — etapes reliees par un fil (horizontal en
  // desktop, vertical en mobile). Badge numerote bleu plein + petite icone, le
  // contenu en carte se souleve au survol/focus. La cascade vient de .reveal.
  // ---------------------------------------------------------------------------
  .parcours {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);

    @include bp("md") {
      position: relative;
      flex-direction: row;
      align-items: stretch;
      gap: var(--space-6);
    }
  }

  // Fil horizontal derriere les badges (desktop), du premier au dernier badge.
  @include bp("md") {
    .parcours::before {
      content: "";
      position: absolute;
      top: 1.7rem;
      left: 16.6%;
      right: 16.6%;
      height: 2px;
      background-color: var(--color-brand-100);
      z-index: 0;
    }
  }

  .parcours__etape {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: start;

    @include bp("md") {
      flex: 1;
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
      justify-items: center;
      gap: var(--space-5);
      text-align: center;
    }
  }

  // Fil vertical reliant les badges (mobile uniquement).
  .parcours__etape:not(:last-child)::before {
    content: "";
    position: absolute;
    top: 3.4rem;
    left: calc(1.7rem - 1px);
    bottom: calc(-1 * var(--space-7));
    width: 2px;
    background-color: var(--color-brand-100);

    @include bp("md") {
      display: none;
    }
  }

  .parcours__badge {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 3.4rem;
    height: 3.4rem;
    border-radius: var(--radius-pill);
    background-color: var(--color-brand-600);
    box-shadow: 0 0 0 5px var(--color-surface), var(--shadow-sm);
  }

  .parcours__num {
    font-size: var(--fs-lg);
    font-weight: var(--fw-bold);
    color: #ffffff;
  }

  .parcours__content {
    width: 100%;
    height: 100%;
    padding: var(--space-5) var(--space-6);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-base),
      box-shadow var(--transition-base), border-color var(--transition-base);
  }

  .parcours__etape:hover .parcours__content,
  .parcours__etape:focus-within .parcours__content {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-ink-300);
  }

  .parcours__icon {
    display: inline-grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    margin-bottom: var(--space-3);
    color: var(--color-brand-600);
    background-color: var(--color-brand-50);
    border-radius: var(--radius-md);

    @include bp("md") {
      margin-inline: auto;
    }
  }

  .parcours__titre {
    font-size: var(--fs-md);
    margin-bottom: var(--space-2);
  }

  .parcours__texte {
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .parcours__content {
      transition: none;
    }

    .parcours__etape:hover .parcours__content,
    .parcours__etape:focus-within .parcours__content {
      transform: none;
    }
  }

  // ---------------------------------------------------------------------------
  // Engagements "Pourquoi Garbi-Protect" — intro a gauche, grille a droite.
  // Tuiles d'icone bleu plein (icone blanche), survol = lift + liseré cyan.
  // Profondeur via un grand hexagone de marque tres discret en fond de section.
  // ---------------------------------------------------------------------------
  .engagements-section {
    position: relative;
    overflow: hidden;
  }

  .engagements-section::before {
    content: "";
    position: absolute;
    z-index: 0;
    width: 36rem;
    height: 40rem;
    right: -9rem;
    bottom: -13rem;
    background-color: var(--color-brand-100);
    opacity: 0.35;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    pointer-events: none;
  }

  .engagements {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-8);

    @include bp("lg") {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--space-9);
      align-items: start;
    }
  }

  .engagements__cta {
    margin-top: var(--space-6);
  }

  .engagements__grid {
    display: grid;
    gap: var(--space-4);

    @include bp("sm") {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
  }

  .engagement {
    position: relative;
    padding: var(--space-6);
  }

  .engagement::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background-color: var(--color-accent);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .engagement:hover,
  .engagement:focus-within {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-ink-300);
  }

  .engagement:hover::before,
  .engagement:focus-within::before {
    opacity: 1;
  }

  .engagement__icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    margin-bottom: var(--space-4);
    color: #ffffff;
    background-color: var(--color-brand-600);
    border-radius: var(--radius-md);
  }

  .engagement__titre {
    font-size: var(--fs-md);
    margin-bottom: var(--space-2);
  }

  .engagement__texte {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .engagement,
    .engagement::before {
      transition: none;
    }

    .engagement:hover,
    .engagement:focus-within {
      transform: none;
    }
  }

  // ---------------------------------------------------------------------------
  // Zones — pastilles departementales.
  // ---------------------------------------------------------------------------
  .zones {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .zone {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    color: var(--color-ink-700);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-xs);
    transition: color var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-base), transform var(--transition-base);
  }

  .zone:hover {
    color: var(--color-brand-700);
    border-color: var(--color-brand-300);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .zone__code {
    font-weight: var(--fw-bold);
    color: var(--color-brand-600);
  }

  .zone__nom {
    font-size: var(--fs-sm);
  }

  // ---------------------------------------------------------------------------
  // Tarifs — trois cartes de forfaits, prix "a partir de", liste de ce qui est
  // inclus, bouton devis. Identite bleue, ombres du site, pas de degrade.
  // ---------------------------------------------------------------------------
  .tarifs__rappel {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-5);
    padding: var(--space-2) var(--space-4);
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--color-brand-700);
    background-color: var(--color-brand-50);
    border: 1px solid var(--color-brand-100);
    border-radius: var(--radius-pill);
  }

  .tarifs__check {
    flex-shrink: 0;
    color: var(--color-brand-500);
  }

  .tarifs {
    display: grid;
    gap: var(--space-5);

    @include bp("md") {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .tarif {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--space-7) var(--space-6);
  }

  // Lisere cyan de marque qui apparait en haut de la carte au survol/focus.
  // Le .card de base gere deja la transition d'elevation, d'ombre et de bordure.
  .tarif::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background-color: var(--color-accent);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  // Pas de dependance au pointeur : le focus clavier (sur le bouton "Obtenir un
  // devis" de la carte) declenche exactement le meme etat que le survol.
  .tarif:hover,
  .tarif:focus-within {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-ink-300);
  }

  .tarif:hover::before,
  .tarif:focus-within::before {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .tarif,
    .tarif::before {
      transition: none;
    }

    .tarif:hover,
    .tarif:focus-within {
      transform: none;
    }
  }

  .tarif__head {
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }

  .tarif__titre {
    font-size: var(--fs-lg);
  }

  .tarif__prix {
    display: flex;
    flex-direction: column;
    margin-top: var(--space-4);
  }

  .tarif__from {
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-brand-600);
  }

  .tarif__value {
    font-size: var(--fs-3xl);
    font-weight: var(--fw-bold);
    line-height: 1.05;
    color: var(--color-brand-700);
  }

  .tarif__soustitre {
    margin-top: var(--space-3);
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  .tarif__inclus {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-5);
    margin-bottom: var(--space-6);
  }

  .tarif__inclus li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-ink-700);
  }

  .tarif__tick {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--color-brand-500);
  }

  .tarif__cta {
    width: 100%;
    margin-top: auto;
  }

  // ---------------------------------------------------------------------------
  // Avis Google — mur d'avis reels qui defile doucement (3 colonnes a vitesses
  // differentes), cartes propres, avatar a initiales sur bleu de marque. Le
  // defilement se met en pause au survol et s'arrete avec prefers-reduced-motion.
  // ---------------------------------------------------------------------------
  // Note moyenne mise en avant sous le titre : etoiles pleines + "5 sur 5" +
  // nombre d'avis, dans une pastille blanche bien lisible.
  .avis-note {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-3);
    margin-top: var(--space-5);
    padding: var(--space-3) var(--space-5);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
  }

  .avis-note__stars {
    display: inline-flex;
    gap: 2px;
  }

  .avis-note__stars .star {
    width: 1.35rem;
    height: 1.35rem;
  }

  .avis-note__score {
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    color: var(--color-ink-900);
  }

  .avis-note__count {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
  }

  .avis-note__count::before {
    content: "";
    width: 4px;
    height: 4px;
    border-radius: var(--radius-pill);
    background-color: var(--color-ink-300);
  }

  .avis__cta {
    margin-top: var(--space-5);
  }

  .star {
    width: 1.05rem;
    height: 1.05rem;
    fill: none;
    stroke: var(--color-ink-300);
    stroke-width: 1.5;
  }

  .star--on {
    fill: var(--color-brand-500);
    stroke: var(--color-brand-500);
  }

  .avis-wall {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    max-height: 38rem;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent,
      #000 12%,
      #000 88%,
      transparent
    );
    mask-image: linear-gradient(
      to bottom,
      transparent,
      #000 12%,
      #000 88%,
      transparent
    );

    @include bp("md") {
      grid-template-columns: repeat(2, 1fr);
    }

    @include bp("lg") {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .avis-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-bottom: var(--space-5);
    will-change: transform;
    animation: avis-scroll var(--avis-duration, 32s) linear infinite;
  }

  .avis-col--2 {
    display: none;

    @include bp("md") {
      display: flex;
    }
  }

  .avis-col--3 {
    display: none;

    @include bp("lg") {
      display: flex;
    }
  }

  .avis-wall:hover .avis-col,
  .avis-wall:focus-within .avis-col {
    animation-play-state: paused;
  }

  @keyframes avis-scroll {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-50%);
    }
  }

  .avis-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
  }

  .avis-card__stars {
    display: inline-flex;
    gap: 2px;
  }

  .avis-card__text {
    color: var(--color-ink-700);
    line-height: var(--lh-snug);
  }

  .avis-card__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .avis-card__avatar {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    flex-shrink: 0;
    border-radius: var(--radius-pill);
    background-color: var(--color-brand-500);
    color: #ffffff;
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
  }

  .avis-card__meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .avis-card__name {
    font-weight: var(--fw-semibold);
    color: var(--color-ink-900);
  }

  .avis-card__source {
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .avis-wall {
      max-height: none;
      overflow: visible;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .avis-col {
      animation: none;
      padding-bottom: 0;
    }

    .avis-card[aria-hidden="true"] {
      display: none;
    }
  }

  // ---------------------------------------------------------------------------
  // Demande de devis — bandeau bleu de cloture. Texte a gauche, carte blanche
  // avec un apercu du formulaire a droite. Le formulaire complet vit sur /devis.
  // ---------------------------------------------------------------------------
  .devis {
    color: var(--color-on-brand);
    background-color: var(--color-brand-700);
    background-image: linear-gradient(
      160deg,
      var(--color-brand-600) 0%,
      var(--color-brand-800) 100%
    );
  }

  .devis__inner {
    display: grid;
    gap: var(--space-7);
    padding-block: var(--space-9);

    @include bp("lg") {
      grid-template-columns: 1fr 0.9fr;
      align-items: center;
      gap: var(--space-9);
    }
  }

  .devis__eyebrow {
    color: var(--color-brand-200);
    margin-bottom: var(--space-4);
  }

  .devis__titre {
    color: var(--color-on-brand);
    max-width: 16ch;
  }

  .devis__lead {
    margin-top: var(--space-4);
    max-width: 46ch;
    font-size: var(--fs-md);
    color: var(--color-brand-100);
  }

  .devis__call {
    margin-top: var(--space-5);
    color: var(--color-brand-100);
  }

  .devis__call a {
    color: var(--color-on-brand);
    font-weight: var(--fw-semibold);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .devis__call a:hover {
    color: var(--color-brand-100);
  }

  .devis__card {
    padding: var(--space-6);
  }

  .devis__card-title {
    margin-bottom: var(--space-5);
    font-weight: var(--fw-semibold);
    color: var(--color-ink-900);
  }

  .field {
    margin-bottom: var(--space-4);
  }

  .field__label {
    display: block;
    margin-bottom: var(--space-2);
    font-size: var(--fs-sm);
    font-weight: var(--fw-medium);
    color: var(--color-ink-700);
  }

  .field__input {
    width: 100%;
    padding: 0.7rem 0.9rem;
    font-family: inherit;
    font-size: var(--fs-base);
    color: var(--color-ink-900);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

